# Carregamento (mesma pasta que pyproject.toml), do menor para maior prioridade:
#   .env.example  →  .env  →  .env.local (último ganha)
# Podes colocar OPENAI_API_KEY aqui em desenvolvimento; em produção use só .env.

APP_ENV=development
LOG_LEVEL=INFO

# OpenAI API — https://platform.openai.com/api-keys (obrigatório no ficheiro .env)
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=120
