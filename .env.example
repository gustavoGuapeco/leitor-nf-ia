# Carregamento (mesma pasta que pyproject.toml), do menor para maior prioridade:
#   .env.example  →  .env  →  .env.local (último ganha)
# Podes colocar OPENAI_API_KEY aqui em desenvolvimento; em produção use só .env.

APP_ENV=development
LOG_LEVEL=INFO

# Provedor de IA (padrão: openai). Chave continua em OPENAI_API_KEY.
AI_PROVIDER=openai

# Modelo e timeout: use AI_* ou, por compatibilidade, OPENAI_*.
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=120
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_TIMEOUT_SECONDS=120

# OpenAI API — https://platform.openai.com/api-keys
# Pode ficar vazio aqui e usar só .env.secrets.local (gerado por scripts/fetch-secrets.ps1 / .sh).
OPENAI_API_KEY=
